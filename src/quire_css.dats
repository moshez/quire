(* inject_toc_css: allocate, fill, inject as <style> element. *)
implement inject_toc_css {l}
  (pf_z | s, parent) = let
  prval _ = pf_z  (* consumed: proves z-index clears scrubber layer *)
  val toc_arr = ward_arr_alloc<byte>(TOC_CSS_LEN)
  val () = fill_toc_all(toc_arr, TOC_CSS_LEN)
  val toc_style_id = dom_next_id()
  val s = ward_dom_stream_create_element(s, toc_style_id, parent, tag_style(), 5)
  val @(frozen, borrow) = ward_arr_freeze<byte>(toc_arr)
  val s = ward_dom_stream_set_text(s, toc_style_id, borrow, TOC_CSS_LEN)
  val () = ward_arr_drop<byte>(frozen, borrow)
  val toc_arr = ward_arr_thaw<byte>(frozen)
  val () = ward_arr_free<byte>(toc_arr)
in s end

