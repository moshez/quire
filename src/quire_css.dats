implement inject_search_css {l}
  (pf_z | s, parent) = let
  prval _ = pf_z
  val search_arr = ward_arr_alloc<byte>(SEARCH_CSS_LEN)
  val () = fill_search_css(search_arr, SEARCH_CSS_LEN)
  val search_style_id = dom_next_id()
  val s = ward_dom_stream_create_element(s, search_style_id, parent, tag_style(), 5)
  val @(frozen, borrow) = ward_arr_freeze<byte>(search_arr)
  val s = ward_dom_stream_set_text(s, search_style_id, borrow, SEARCH_CSS_LEN)
  val () = ward_arr_drop<byte>(frozen, borrow)
  val search_arr = ward_arr_thaw<byte>(frozen)
  val () = ward_arr_free<byte>(search_arr)
in s end
