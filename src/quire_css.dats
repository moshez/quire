(* inject_stg_css: allocate, fill, inject as <style> element. *)
implement inject_stg_css {l}
  (pf_z | s, parent) = let
  prval _ = pf_z
  val stg_arr = ward_arr_alloc<byte>(STG_CSS_LEN)
  val () = fill_stg_css(stg_arr, STG_CSS_LEN)
  val stg_style_id = dom_next_id()
  val s = ward_dom_stream_create_element(s, stg_style_id, parent, tag_style(), 5)
  val @(frozen, borrow) = ward_arr_freeze<byte>(stg_arr)
  val s = ward_dom_stream_set_text(s, stg_style_id, borrow, STG_CSS_LEN)
  val () = ward_arr_drop<byte>(frozen, borrow)
  val stg_arr = ward_arr_thaw<byte>(frozen)
  val () = ward_arr_free<byte>(stg_arr)
in s end

