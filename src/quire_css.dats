(* inject_scrub_css: allocate, fill, inject as <style> element.
 * Proofs on signature — no praxi. *)
implement inject_scrub_css {l}
  (pf_tap, pf_vis | s, parent) = let
  prval _ = pf_tap  (* consumed: proves touch targets OK *)
  prval _ = pf_vis  (* consumed: proves visibility OK *)
  val scrub_arr = ward_arr_alloc<byte>(SCRUB_CSS_LEN)
  val () = fill_scrub_all(scrub_arr, SCRUB_CSS_LEN)
  val scrub_style_id = dom_next_id()
  val s = ward_dom_stream_create_element(s, scrub_style_id, parent, tag_style(), 5)
  val @(frozen, borrow) = ward_arr_freeze<byte>(scrub_arr)
  val s = ward_dom_stream_set_text(s, scrub_style_id, borrow, SCRUB_CSS_LEN)
  val () = ward_arr_drop<byte>(frozen, borrow)
  val scrub_arr = ward_arr_thaw<byte>(frozen)
  val () = ward_arr_free<byte>(scrub_arr)
in s end

